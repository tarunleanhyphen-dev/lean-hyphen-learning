# Frontend environment variables
# Copy to .env.local for local dev (Vite auto-loads it).
# In production (Vercel), set these in the Project → Settings → Environment Variables.

# Base URL of the backend API. Leave blank to use the Vite dev proxy at /api.
VITE_API_BASE_URL=

# ────────────────────────────────────────────────────────────
# Supabase (OPTIONAL on frontend — only needed for Auth / direct
# DB reads / Storage / Realtime). Existing API routes work without it.
# ────────────────────────────────────────────────────────────
# From Supabase → Project Settings → API:
#   VITE_SUPABASE_URL       = "Project URL"   (https://<ref>.supabase.co)
#   VITE_SUPABASE_ANON_KEY  = "anon public" key (safe to ship in the bundle;
#                             Row-Level Security on the DB enforces access).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
