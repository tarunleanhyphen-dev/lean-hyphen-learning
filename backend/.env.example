# Backend environment variables. Copy to `.env` and fill in.
PORT=4000

# Postgres connection string.
# - Neon free tier: get this from https://console.neon.tech → "Connection string"
# - Local Postgres: postgres://user:pass@localhost:5432/leanhyphen
DATABASE_URL=

# If your DATABASE_URL hits a host that requires SSL (Neon does), keep true.
# For purely local Postgres, set to false.
PGSSL=true

# CORS — comma-separated list of allowed origins. Leave empty for "allow all" in dev.
CORS_ORIGINS=http://localhost:5173

# ────────────────────────────────────────────────────────────
# ElevenLabs TTS (OPTIONAL — gives a real human-sounding voice)
# ────────────────────────────────────────────────────────────
# When BOTH the API key AND a voice ID are set, /api/tts routes that
# role's audio through ElevenLabs instead of MS Edge Neural. Falls back
# to Edge automatically if ElevenLabs fails or the vars are missing.
#
# Setup (free tier covers 10k chars/month):
#   1. Sign up at https://elevenlabs.io/sign-up
#   2. Profile → API Keys → copy your `xi-...` key → paste below.
#   3. https://elevenlabs.io/app/voice-library → filter
#      Language: English (Indian) + Gender: Male → preview → "Add to My Voices".
#   4. From "My Voices" → click the voice → copy the Voice ID
#      (looks like 21m00Tcm4TlvDq8ikWAM).
#   5. Paste it into ELEVENLABS_VOICE_NARRATOR below + restart backend.
#
# Override Shanaya the same way with ELEVENLABS_VOICE_SHANAYA. Leave
# blank to keep her on Edge's hi-IN-SwaraNeural.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_NARRATOR=
ELEVENLABS_VOICE_SHANAYA=
